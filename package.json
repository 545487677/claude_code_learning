{
  "name": "claude-code-cicd-scripts",
  "version": "1.0.0",
  "description": "CI/CD automation scripts for branch cleanup and maintenance",
  "type": "module",
  "scripts": {
    "cleanup:preview": "bash scripts/cleanup-branches.sh --dry-run",
    "cleanup:execute": "bash scripts/cleanup-branches.sh",
    "ai-cleanup": "tsx scripts/ai-cleanup.ts",
    "ai-cleanup:auto": "AUTO_EXECUTE=true tsx scripts/ai-cleanup.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "ci-cd",
    "automation",
    "git",
    "branch-cleanup",
    "claude-code"
  ]
}
